# このファイルは terraform.tfvars にコピーして使う。

aws_region = "ap-northeast-1"

# 別アカウントへの誤デプロイ防止のため必須。
# ~/.aws/credentials / ~/.aws/config に登録したプロファイル名を指定する。
aws_profile = "sales-booster-prod"

# 12 桁の AWS アカウント ID。`aws sts get-caller-identity --profile <名前>` で確認可能。
# Apply 時に現在の credential のアカウントと一致しないと止まる。
expected_account_id = "123456789012"

amplify_log_group_names = [
  # CloudWatch Logs コンソールで Amplify アプリ ID を含むロググループを
  # 全て列挙する。例:
  # "/aws/lambda/main-XXXXXXXXXXXXXX",
  # "/aws/lambda/develop-XXXXXXXXXXXXXX",
]

# 全ログを転送する場合は空文字列。エラーだけに絞るなら次のように:
# subscription_filter_pattern = "{$.level = \"error\"}"
subscription_filter_pattern = ""
